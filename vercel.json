{
  "crons": [
    {
      "path": "/api/sync-emails",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/backfill-emails",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/standup-weekly",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/agent-expire-approvals",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/backfill-bodies",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/follow-up-ghl-appointment-poll",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/follow-up-ghl-conversations-poll",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/follow-up-admin-daily",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/follow-up-admin-weekly",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/cron-lisa-delayed",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron-finance-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron-bank-sync",
      "schedule": "15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
